# Copy this file to .env.local and fill in your Supabase project's values
# (Settings -> API in the Supabase dashboard). Only the public anon key goes
# here — never the service_role key, and never any AI vendor key (those are
# Supabase Edge Function secrets, set with `supabase secrets set`).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
